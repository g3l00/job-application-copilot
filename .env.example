OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5.4-mini
PORT=8787

# Optional database. Leave empty locally to use SQLite at data/applypilot.sqlite.
# Set on Render automatically from render.yaml.
DATABASE_URL=
POSTGRES_SSL=true

# Optional private deployment login.
APP_USERNAME=applypilot
APP_PASSWORD=choose-a-strong-password

# Optional Gmail API import.
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8787/api/gmail/oauth/callback
GMAIL_QUERY=from:linkedin.com newer_than:2d
GMAIL_MAX_RESULTS=10
